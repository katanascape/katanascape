{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "mocha"],
    "moduleResolution": "node16",
    "resolveJsonModule": true
  },
  "include": ["tests/**/*.ts", "packages/**/*.ts", "examples/**/*.ts"]
}
